# ================================================
# AarogyaOne Backend — Environment Variables
# ================================================
# Copy this file to .env and fill in your real values.
# NEVER commit the real .env to version control.
# ================================================

# ---- Supabase (Managed PostgreSQL + Storage + Realtime) ----
# Get from: Supabase Dashboard → Project Settings → API

# Transaction Pooler URL (port 6543, for serverless/short-lived connections)
DATABASE_URL=postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[YOUR_REGION].pooler.supabase.com:6543/postgres

SUPABASE_URL=https://[YOUR_PROJECT_REF].supabase.co 

# Service Role key — NEVER expose to frontend. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# Anon/Public key — safe for frontend Realtime subscriptions
SUPABASE_ANON_KEY=your_supabase_anon_key_here
# ---- Firebase Admin SDK (for verifying Firebase ID Tokens) ----
# Download from Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# Place the JSON file at backend/firebase-adminsdk.json
FIREBASE_PROJECT_ID=your_firebase_project_id_here
FIREBASE_ADMIN_CREDENTIALS_PATH=./firebase-adminsdk.json

# ---- Supabase Storage Buckets ----
SUPABASE_BUCKET_COMPLAINT_MEDIA=complaint-media
SUPABASE_BUCKET_INFRA_PHOTOS=infrastructure-photos
SUPABASE_BUCKET_COMPLETION_EVIDENCE=completion-evidence
SUPABASE_BUCKET_REPORTS=reports

# ---- App Settings ----
APP_NAME=AarogyaOne
APP_VERSION=1.0.0
DEBUG=True
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
